{
  "name": "prysma-language-support",
  "displayName": "Prysma Language Support",
  "description": "Syntax highlighting and color customization for Prysma files.",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "prysma",
      "aliases": ["Prysma", "prysma"],
      "extensions": [".p"]
    }],
    "grammars": [{
      "language": "prysma",
      "scopeName": "source.prysma",
      "path": "./prysma.tmLanguage.json"
    }]
  }
}
